span class="line"></span><br><span class="line">  <span class="keyword">while</span> ( <span class="number">1</span> )</span><br><span class="line"></span><br><span class="line">  &#123;</span><br><span class="line"></span><br><span class="line">    v1 = v4++;</span><br><span class="line"></span><br><span class="line">    result = (<span class="type">unsigned</span> __int8)*v1;</span><br><span class="line"></span><br><span class="line">    v3 = result;</span><br><span class="line"></span><br><span class="line">    <span class="keyword">if</span> ( !(_BYTE)result )</span><br><span class="line"></span><br><span class="line">      <span class="keyword">break</span>;</span><br><span class="line"></span><br><span class="line">    <span class="keyword">if</span> ( (<span class="type">char</span>)result &lt;= <span class="number">96</span> || (<span class="type">char</span>)result &gt; <span class="number">123</span> )</span><br><span class="line"></span><br><span class="line">      explode_bomb();</span><br><span class="line"></span><br><span class="line">    v0 = v5++;</span><br><span class="line"></span><br><span class="line">    <span class="keyword">if</span> ( *v0 != keys[v3 - <span class="number">97</span>] )</span><br><span class="line"></span><br><span class="line">      explode_bomb();</span><br><span class="line"></span><br><span class="line">    lastentered = v3;</span><br><span class="line"></span><br><span class="line">  &#125;</span><br><span class="line"></span><br><span class="line">  phase3_solved = <span class="number">1</span>;</span><br><span class="line"></span><br><span class="line">  <span class="keyword">return</span> result;</span><br><span class="line"></span><br><span class="line">&#125;</span><br><span class="line"></span><br></pre></td></tr></table></figure>

