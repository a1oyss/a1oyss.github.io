        &quot;cyan&quot;: &quot;#578e57&quot;,
        &quot;white&quot;: &quot;#978771&quot;,
        &quot;brightBlack&quot;: &quot;#7f7061&quot;,
        &quot;brightRed&quot;: &quot;#f73028&quot;,
