            // 背景图片不透明度
            &quot;backgroundImageOpacity&quot;:0.6,
            &quot;hidden&quot;: false
        &#125;,
        &#123;
            // cmd配置
            &quot;guid&quot;: &quot;&#123;0caa0dad-35be-5f56-a8ff-afceeeaa6101&#125;&quot;,
