            &quot;commandline&quot;: &quot;powershell.exe&quot;,
            // 启动时位置
            &quot;startingDirectory&quot;: &quot;D:/&quot;,
            // 字体
            &quot;fontFace&quot;: &quot;Cascadia Code PL&quot;,
            // 启用 acrylic 背景，这里自行调整
